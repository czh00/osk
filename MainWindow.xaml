<Window x:Class="OSK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="OSK" Height="330" Width="1000" 
        Topmost="True" WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        Background="{x:Null}" 
        Stylus.IsPressAndHoldEnabled="False" Stylus.IsFlicksEnabled="False" Stylus.IsTapFeedbackEnabled="False"

        Stylus.IsTouchFeedbackEnabled="False"
        ResizeMode="NoResize" Name="RootWindow"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp"
        PreviewTouchMove="Window_PreviewTouchMove"
        PreviewTouchUp="Window_PreviewTouchUp"
        ManipulationBoundaryFeedback="Window_ManipulationBoundaryFeedback">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" CornerRadius="10" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
    </Window.Resources>
    
    <!-- VirtualScreen Canvas allowing full unbounded movement -->
    <Canvas x:Name="VirtualCanvas" Background="{x:Null}">
        <Border x:Name="KeyboardContainer" CornerRadius="10" Background="{Binding WindowBackground}" ClipToBounds="False">
            <Grid x:Name="MainRootGrid" Background="Transparent" ClipToBounds="False">
                <!-- 右下角 Resize Grip：綁定 ResizeGripColor -->
            <Grid VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="25" Height="25" Cursor="SizeNWSE" MouseLeftButtonDown="Resize_Init" MouseMove="Resize_Move" MouseLeftButtonUp="Resize_End" Panel.ZIndex="100" Background="Transparent" Visibility="{Binding ResizeGripVisibility}">
                <Path Data="M0,25 L25,25 L25,0 Z" Fill="{Binding ResizeGripColor}"/>
                <Path Data="M10,25 L25,10 M15,25 L25,15 M20,25 L25,20" Stroke="{Binding ResizeGripColor}" StrokeThickness="1"/>
            </Grid>
            <Grid Margin="1,1,1,0" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 頂部拖曳區 (限縮於此區域) -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown" TouchDown="TopTitleBar_TouchDown" TouchMove="TopTitleBar_TouchMove" TouchUp="TopTitleBar_TouchUp">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                </Grid.LayoutTransform>
                <TextBlock Text="{Binding CurrentAppInfo}" 
                           Foreground="{Binding UiTextColor}" 
                           Opacity="0.6"
                           FontSize="13" 
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Top" 
                           Margin="10,5,0,0" 
                           IsHitTestVisible="False" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,5" Panel.ZIndex="50">
                    <!-- 全鍵盤/精簡版面切換按鈕 -->
                    <Button Command="{Binding ToggleFullLayoutCommand}" 
                            Content="{Binding FullLayoutIcon}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding UiTextColor}"
                            FontSize="16"
                            Margin="0,0,5,0"
                            ToolTip="切換 100% / 60% 版面" />

                    <!-- 動態/靜態版面切換按鈕 -->
                    <Button Command="{Binding ToggleLayoutCommand}" 
                            Content="{Binding LayoutIcon}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding UiTextColor}"
                            FontSize="16"
                            Margin="0,0,5,0"
                            ToolTip="切換 動態/靜態 版面" />
                            
                    <!-- 釘住切換按鈕 -->
                    <Button Command="{Binding TogglePinCommand}" 
                            Content="{Binding PinIcon}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding UiTextColor}"
                            FontSize="16"
                            Margin="0,0,5,0"
                            ToolTip="釘住 / 取消釘住鍵盤 (開啟時不會隨焦點隱藏)" />
                            
                    <!-- 拖移特效開關按鈕 -->
                    <Button Command="{Binding ToggleDragFxCommand}" 
                            Content="{Binding DragFxIcon}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding UiTextColor}"
                            FontSize="16"
                            Margin="0,0,5,0"
                            ToolTip="開關拖移物理特效" />
                            
                    <!-- 主題切換按鈕：綁定 UiTextColor -->
                    <Button Command="{Binding ToggleThemeCommand}" 
                            Content="{Binding ThemeIcon}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{Binding UiTextColor}"
                            FontSize="16"
                            Margin="0,0,10,0"
                            ToolTip="切換 深色/淺色 模式" />
                    
                    <!-- 透明度文字：綁定 UiTextColor -->
                    <TextBlock Text="透明度: " Foreground="{Binding UiTextColor}" VerticalAlignment="Center"/>
                    
                    <!-- Slider：綁定 Foreground 來控制刻度顏色 (如果有顯示刻度)，主要依靠滑軌樣式 -->
                    <Slider x:Name="OpacitySlider" IsMoveToPointEnabled="True" 
                            Value="{Binding Opacity, ElementName=RootWindow}" 
                            Minimum="0.2" Maximum="1.0" Width="80" VerticalAlignment="Center" Focusable="true" Margin="5,0,10,0"
                            Foreground="{Binding UiTextColor}"/>
                    
                    <!-- 恢復預設尺寸按鈕 -->
                    <Button Content=" ⟲ " Click="RestoreSize_Click" Width="30" Height="25" Margin="0,0,2,0" 
                            Background="{Binding ControlBtnBackground}" 
                            Foreground="{Binding UiTextColor}"
                            FontWeight="Bold" BorderThickness="0"
                            ToolTip="恢復預設配置(包含版面與透明度)"/>
                            
                    <!-- 設定按鈕 (版面編輯) -->
                    <Button Content=" ⚙ " Command="{Binding ToggleEditModeCommand}" Width="30" Height="25" Margin="0,0,2,0" 
                            Background="{Binding ControlBtnBackground}" 
                            Foreground="{Binding SettingsBtnColor}"
                            FontWeight="Bold" BorderThickness="0"
                            ToolTip="編輯按鈕位置"/>
                            
                    <!-- 最小化按鈕：文字綁定 UiTextColor，背景綁定 ControlBtnBackground -->
                    <Button Content=" 🗕 " Click="Minimize_Click" Width="30" Height="25" Margin="0,0,2,0" 
                            Background="{Binding ControlBtnBackground}" 
                            Foreground="{Binding UiTextColor}"
                            FontWeight="Bold" BorderThickness="0"/>
                    
                    <!-- 關閉按鈕：維持紅色背景，文字固定白色，確保警示意味 -->
                    <Button Content=" ✕ " Click="Exit_Click" Width="30" Height="25" Margin="2,0,0,0" 
                            Background="#993333" 
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
            <Viewbox Grid.Row="1" Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <ItemsControl Name="KeyBoardItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding}" ClipToBounds="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="{Binding DataContext.KeyboardAlignment, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6"
                                                Background="{Binding Background}"
                                                Width="{Binding Width}"
                                                Height="{Binding Height}"
                                                Margin="{Binding Margin}"
                                                VerticalAlignment="Top"
                                                Panel.ZIndex="10"
                                                Cursor="Hand"
                                                RenderTransformOrigin="0.5,0.5"
                                                MouseEnter="KeyBorder_MouseEnter"
                                                MouseDown="KeyBorder_MouseDown"
                                                MouseUp="KeyBorder_MouseUp"
                                                MouseLeave="KeyBorder_MouseLeave"
                                                TouchDown="KeyBorder_TouchDown"
                                                TouchUp="KeyBorder_TouchUp"
                                                TouchLeave="KeyBorder_TouchLeave"
                                                PreviewMouseLeftButtonDown="KeyBorder_PreviewMouseLeftButtonDown"
                                                 PreviewTouchDown="KeyBorder_PreviewTouchDown">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Viewbox x:Name="StaticLayout" Stretch="Uniform" StretchDirection="Both" Margin="2">
                                                    <Grid Width="50" Height="50">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <Viewbox Grid.Row="0" Grid.Column="0" Grid.RowSpan="{Binding MainRowSpan}" Grid.ColumnSpan="{Binding MainColSpan}" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="{Binding MainHorizontalAlignment}" VerticalAlignment="{Binding MainVerticalAlignment}" Margin="1">
                                                            <TextBlock Text="{Binding EnglishDisp}" Foreground="{Binding TextColor}" FontSize="24" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                                                        </Viewbox>
                                                        <Viewbox Grid.Row="0" Grid.Column="1" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1">
                                                            <TextBlock Text="{Binding ShiftDisp}" Foreground="{Binding ShiftColor}" FontSize="20" FontFamily="Segoe UI" />
                                                        </Viewbox>
                                                        <Viewbox Grid.Row="1" Grid.Column="0" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1">
                                                            <TextBlock Text="{Binding FnDisp}" Foreground="{Binding FnColor}" FontSize="16" FontFamily="Segoe UI" />
                                                        </Viewbox>
                                                        <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1">
                                                            <TextBlock Text="{Binding ZhuyinDisp}" Foreground="{Binding ZhuyinColor}" FontSize="18" FontFamily="Segoe UI" />
                                                        </Viewbox>
                                                    </Grid>
                                                </Viewbox>
                                                <Viewbox x:Name="DynamicLayout" Stretch="Uniform" StretchDirection="Both" Margin="4" Visibility="Collapsed">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{Binding DynamicTextColor}" FontSize="24" FontFamily="Segoe UI" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsDynamicLayout, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter TargetName="StaticLayout" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="DynamicLayout" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,0,0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                    <Canvas x:Name="DragOverlay" IsHitTestVisible="False" Panel.ZIndex="1000"/>
                </Grid>
            </Viewbox>
        </Grid>
            </Grid>
        </Border>
    </Canvas>
</Window>